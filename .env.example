# Copy this file to .env and fill in real values. .env itself is gitignored.
# These EXPO_PUBLIC_* vars are bundled into the mobile app and safe to expose
# (Supabase publishable/anon keys are designed for client use; RLS guards data).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_YOUR_PUBLISHABLE_KEY

# Server-side secrets (Qwen API key, Supabase service role key, OCR extractor URL, etc.)
# do NOT belong here. Set them as Supabase Edge Function secrets:
#   supabase secrets set QWEN_API_KEY=sk-...
#   supabase secrets set EXTRACTOR_URL=https://...
# See supabase/functions/*/index.ts for the full list each function expects.
